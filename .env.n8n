# n8n Self-Hosted Configuration

# n8n Base URL (for local development)
N8N_HOST=http://localhost:5678
# For production with Cloudflare Tunnel:
# N8N_HOST=https://repairmax.n8n.app

# n8n Webhook URL (where n8n can be accessed from)
# For local: http://localhost:5678
# For production: https://repairmax.n8n.app
N8N_WEBHOOK_URL=http://localhost:5678

# Laravel API Base URL
LARAVEL_API_URL=http://localhost:8000

# For webhooks from n8n to Laravel (must be accessible from n8n container)
# This should be your Laravel API endpoint
LARAVEL_WEBHOOK_URL=http://host.docker.internal:8000

# Enable n8n metrics and monitoring
N8N_METRICS=true
